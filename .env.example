# --- CONFIGURATION BASE DE DONNÉES ---
# Nom de la base de données (ex: mo5_rag_db)
DB_NAME=
# Utilisateur Postgres (ex: admin)
DB_USER=
# Mot de passe (À RENSEIGNIER IMPÉRATIVEMENT)
DB_PASSWORD=

# --- CONFIGURATION IA / EMBEDDING ---
# Modèle utilisé par l'API Python (ex: intfloat/multilingual-e5-small)
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# --- SÉCURITÉ API ---
# Clé secrète pour autoriser les requêtes vers le serveur RAG
API_KEY=

# --- RATE LIMITING ---
# Activer/désactiver le rate limiting (true/false)
RATE_LIMIT_ENABLED=true
# Nombre maximum de requêtes par minute par IP
RATE_LIMIT_REQUESTS_PER_MINUTE=30
# Nombre maximum de requêtes par heure par IP
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# --- ANTI-BRUTE-FORCE ---
# Activer/désactiver la protection anti-brute-force (true/false)
BRUTE_FORCE_ENABLED=true
# Nombre maximum de tentatives échouées avant blocage
BRUTE_FORCE_MAX_ATTEMPTS=3
# Durée du blocage en minutes
BRUTE_FORCE_BLOCK_DURATION_MINUTES=30