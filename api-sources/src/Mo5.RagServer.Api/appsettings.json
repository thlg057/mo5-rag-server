{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=mo5_rag;Username=mo5_user;Password=mo5_password"
  },
  "EmbeddingService": {
    "Provider": "Local",
    "VectorDimensions": 384
  },
  "LocalEmbedding": {
    "ModelName": "paraphrase-multilingual-MiniLM-L12-v2",
    "PythonPath": "python"
  },
  "RagSettings": {
    "ChunkSize": 1000,
    "ChunkOverlap": 200,
    "MaxResults": 10,
    "MinSimilarityScore": 0.7,
    "KnowledgeBasePath": "./knowledge",
    "DocsBasePath": "./mo5-docs"
  },
  "ApiKeySettings": {
    "Key": "please-change-this-default"
  },
  "RateLimitSettings": {
    "Enabled": true,
    "RequestsPerMinute": 30,
    "RequestsPerHour": 1000,
    "WhitelistedIps": ["127.0.0.1", "::1"]
  },
  "AntiBruteForceSettings": {
    "Enabled": true,
    "MaxFailedAttempts": 3,
    "BlockDurationMinutes": 30,
    "WhitelistedIps": ["127.0.0.1", "::1"]
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*"
}
